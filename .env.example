OPS_HUB_PASSWORD=
# Shared team password for Fine Hub sign-in and sign-up (e.g. Finecoustic666!).
# Every employee uses this same password with their registered name. No personal passwords.
# Shared team password for appdev sign-in/sign-up (e.g. yscoco_app321). Changing this invalidates appdev sessions.
APPDEV_PASSWORD=

# Required in production — signs session cookies (openssl rand -base64 32)
SESSION_SECRET=

# Master admin password — hub + appdev admin on master login. Keep separate from team passwords.
# Reserved admin display name: FCS-建宏 (see lib/appdev-constants.js)
HUB_MASTER_PASSWORD=

# Per-user hub accounts (signup at /). Requires OPS_HUB_PASSWORD for all sign-in/sign-up.
# Set HUB_PER_USER_AUTH=0 to disable requiring hub login when no passwords are set (local only).
HUB_PER_USER_AUTH=

# Local dev: leave DATABASE_URL blank → reads brands/*/ops-data.json from disk
# Vercel / production: set DATABASE_URL + run npm run db:seed once
DATABASE_URL=

# Preorder questionnaire webhook (Shopify theme POST). Generate: openssl rand -hex 24
PREORDER_SURVEY_SECRET=

# Preorder reserved lookup + hero customer register (Shopify Admin API)
# Token scopes: read_customers, write_customers
SHOPIFY_STORE=j5gawi-vu.myshopify.com
SHOPIFY_ADMIN_TOKEN=

# Production uploads — Cloudinary (preferred) or Vercel Blob. Local dev uses data/appdev-uploads/.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
BLOB_READ_WRITE_TOKEN=
