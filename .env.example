OPS_HUB_PASSWORD=
# Shared team password for appdev sign-in/sign-up (e.g. yscoco_app321). Changing this invalidates appdev sessions.
APPDEV_PASSWORD=

# Required in production — signs session cookies (openssl rand -base64 32)
SESSION_SECRET=

# Master admin password — hub + appdev admin on master login. Keep separate from team passwords.
# Reserved admin display name: FCS-建宏 (see lib/appdev-constants.js)
HUB_MASTER_PASSWORD=

# Local dev: leave DATABASE_URL blank → reads brands/*/ops-data.json from disk
# Vercel / production: set DATABASE_URL + run npm run db:seed once
DATABASE_URL=

# Production uploads — Cloudinary (preferred) or Vercel Blob. Local dev uses data/appdev-uploads/.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
BLOB_READ_WRITE_TOKEN=
